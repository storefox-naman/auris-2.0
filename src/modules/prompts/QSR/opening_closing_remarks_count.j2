      "closing_remarks_mentioned": "yes",
      "closing_remark": "Have a good day.",
      "closing_remarks_start_seconds": 52,
      "closing_remarks_end_seconds": 55
    },
    {
      "interaction_id": 2,
      "opening_remarks_mentioned": "no",
      "opening_remark": "N/A",
      "opening_remarks_start_seconds": -1,
      "opening_remarks_end_seconds": -1,
      "closing_remarks_mentioned": "ambiguous",
      "closing_remark": "undetermined",
      "closing_remarks_start_seconds": -1,
      "closing_remarks_end_seconds": -1
    }
  ]
}
